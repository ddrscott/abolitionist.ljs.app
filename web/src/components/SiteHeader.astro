---
// Shared header used on every page (custom home + Starlight article
// routes via the `components.Header` override in astro.config.mjs).
// Keep this the single source of truth for the top bar.
---

<header class="site-header">
  <a href="/" class="brand">
    <img src="/icon-full.png" alt="" class="brand-mark" />
    <span>Ask the Abolitionist</span>
  </a>
  <nav class="site-nav">
    <a href="/pages/">Articles</a>
    <a href="/pages/journey/">Journey</a>
    <a
      href="https://github.com/ddrscott/abolitionist.ljs.app"
      class="gh-link"
      rel="noopener"
      aria-label="View source on GitHub"
      title="View source on GitHub"
    >
      <svg
        viewBox="0 0 16 16"
        width="20"
        height="20"
        aria-hidden="true"
        focusable="false"
        ><path
          fill="currentColor"
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
        ></path></svg
      >
    </a>
  </nav>
</header>

<style is:global>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1.25rem;
    background: linear-gradient(90deg, #430607 5%, #230102);
    color: #fde8e8;
    border-bottom: 1px solid #c49a6e;
    box-shadow: rgba(0, 0, 0, 0.7) 5px 5px 30px 1px;
  }
  .site-header .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Oswald', Impact, sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #ffffff;
    text-decoration: none;
  }
  .site-header .brand:hover { color: #c49a6e; }
  .site-header .brand-mark {
    width: 34px;
    height: 34px;
    display: block;
  }
  .site-header .site-nav {
    display: inline-flex;
    gap: 1.25rem;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1rem;
  }
  .site-header .site-nav a {
    color: #fde8e8;
    text-decoration: none;
  }
  .site-header .site-nav a:hover { color: #c49a6e; }
  .site-header .site-nav a.gh-link {
    display: inline-flex;
    align-items: center;
    color: #fde8e8;
    opacity: 0.85;
  }
  .site-header .site-nav a.gh-link:hover { opacity: 1; color: #ffffff; }

  /* When rendered inside Starlight's layout, neutralize the default
     site-title + link chrome so we don't double up. */
  :root .header > .site-header {
    flex: 1;
  }
  :root header.header {
    padding: 0 !important;
  }
  :root header.header > *:not(.site-header) {
    display: none !important;
  }
</style>
