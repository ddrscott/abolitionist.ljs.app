# macOS
.DS_Store

# Editor backups
*~
*.swp

# Local Claude Code harness state (commit the queue itself, not the lock).
.claude/scheduled_tasks.lock

# Python — extractor runs via `uv run` with inline deps; no checked-in venv.
__pycache__/
*.pyc
.venv/
.python-version

# web/.gitignore handles its own subtree (.source, node_modules, dist, etc.).

# Scraped / derivative article content — the two source publications'
# writings and everything mined from them. Their copyright belongs to
# the original publishers; we keep them out of git so re-distribution
# stays limited to the live site. Regenerate locally by running the
# extraction pipeline (see scripts/extract_articles.py) against your
# own mirrors of the two sites.
pages/abolitionistsrising.com/
pages/freethestates.org/
pages/index.json
pages/README.md
web/public/questions-index.json
