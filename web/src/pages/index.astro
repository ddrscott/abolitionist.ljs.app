---
import { ChatBox } from '@/components/ChatBox';
import SiteHeader from '@/components/SiteHeader.astro';
import '@/styles/home.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ask the Abolitionist</title>
    <meta
      name="description"
      content="Beta. Straight answers on abortion from the abolitionist movement. An independent project — not affiliated with abolitionistsrising.com or freethestates.org, whose writings it draws from."
    />
    <meta property="og:title" content="Ask the Abolitionist (Beta)" />
    <meta
      property="og:description"
      content="Beta. Straight answers on abortion from the abolitionist movement. An independent project — not affiliated with abolitionistsrising.com or freethestates.org."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://abolitionist.ljs.app/" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/icon-full.png" type="image/png" />
    <link rel="apple-touch-icon" href="/icon-full.png" />
    <script
      defer
      data-domain="abolitionist.ljs.app"
      data-api="https://plausible.ljs.app/api/event"
      src="https://plausible.ljs.app/js/script.js"></script>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="hero">
        <h1>
          Ask the Abolitionist
          <span class="beta-badge" title="Beta — expect rough edges. Feedback welcome via the 👍/👎 on answers.">Beta</span>
        </h1>
        <p class="subhead">
          Straight answers on abortion, grounded in the writings of the
          abolitionist movement to abolish it. For street dialog, for
          conversations with skeptics, or if you&rsquo;re hearing about
          us for the first time.
        </p>
      </section>

      <ChatBox client:load />

      <section class="journey-cta">
        <h2>New to all this? Start where you are.</h2>
        <p>
          The Journey is a short reading path tailored to the position you
          hold today. Seven starting points &mdash; from &ldquo;abortion
          should be legal&rdquo; to &ldquo;I believe it&rsquo;s wrong but
          I&rsquo;m not doing anything.&rdquo; Pick yours.
        </p>
        <a href="/pages/journey/" class="button">Find your starting point →</a>
      </section>

      <footer>
        <div class="footer-row">
          <a href="/pages/">Browse every article →</a>
          <span aria-hidden="true">·</span>
          <code>abolitionistsrising.com</code>
          <code>freethestates.org</code>
        </div>
        <p class="disclaimer">
          Independent project. Not affiliated with or endorsed by
          abolitionistsrising.com or freethestates.org &mdash; this
          site collects and indexes their public writings so readers
          can search and ask questions across both corpora.
        </p>
      </footer>
    </main>
  </body>
</html>
