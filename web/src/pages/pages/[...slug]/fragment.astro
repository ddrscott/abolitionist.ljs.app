---
/**
 * Article body without site chrome — served at
 * `/pages/<site>/<slug>/fragment/`. Used by the Journey map's
 * right-sidebar preview. Works in both `pnpm dev` (on demand) and
 * `pnpm build` (prerendered static file). Replaces the post-build
 * HTML extractor.
 */
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/^pages\//, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = entry.data.title;
// Canonical original-source URL (e.g. https://freethestates.org/…). Exposed
// as a data attribute so the in-app source panel can link "Read the original".
const sourceUrl = entry.data.source_url;
---

<h1 id="_top" data-source-url={sourceUrl}>{title}</h1>
<div class="sl-markdown-content">
  <Content />
</div>
