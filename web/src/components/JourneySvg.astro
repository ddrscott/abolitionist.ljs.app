---
/**
 * Inlines the Journey flowchart SVG into the page in normal flow.
 * On desktop (≥ 1024px), clicking a Read: node fetches the article
 * body as a pre-rendered fragment and injects it into the right
 * sidebar panel — no iframe, full Starlight article styling, with
 * support for `#anchor` in the link scrolling the panel to the
 * targeted section. On narrow viewports the click falls through to
 * a normal full-page navigation.
 *
 * Fragments are emitted post-build by
 * scripts/generate-journey-article-fragments.mjs.
 */
import fs from 'node:fs';
import path from 'node:path';
import url from 'node:url';

const here = path.dirname(url.fileURLToPath(import.meta.url));
const svgPath = path.resolve(here, '../../public/journey-map.svg');
const raw = fs
  .readFileSync(svgPath, 'utf8')
  .replace(/^<\?xml[^?]*\?>\s*/, '')
  .replace('<svg ', '<svg class="journey-svg" ');
---

<figure class="journey-figure">
  <div class="journey-map" set:html={raw} />
  <figcaption>
    Click any &ldquo;Read:&rdquo; box to open that article beside the
    map. On phones it opens the article full-page.
  </figcaption>
</figure>

<style is:global>
  .journey-figure { margin: 1.5rem 0; }
  .journey-figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--sl-color-gray-3, #666);
    text-align: center;
  }
  .journey-map .journey-svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .journey-svg a { cursor: pointer; }
  .journey-svg a:hover rect { filter: brightness(0.95); }
  .journey-svg a:focus-visible rect { outline: 3px solid #cc3206; }

  /* Right-sidebar article panel — injected on Read: click. */
  .journey-rs-panel {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--sl-nav-height, 4rem) - 1rem);
    border: 1px solid var(--sl-color-hairline, #c49a6e);
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }
  .journey-rs-panel > header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    background: #430607;
    color: #fde8e8;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 0.85rem;
    position: sticky;
    top: 0;
    z-index: 2;
  }
  .journey-rs-panel .rs-title {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .journey-rs-panel .rs-pop {
    color: #fde8e8;
    text-decoration: underline;
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .journey-rs-panel .rs-close {
    background: transparent;
    border: 0;
    color: #fde8e8;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .journey-rs-panel .rs-body {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
  }
  .journey-rs-panel .rs-body :is(h1, h2, h3, h4, h5, h6):first-child {
    margin-top: 0;
  }
  .journey-rs-panel .rs-loading,
  .journey-rs-panel .rs-error {
    padding: 1rem 1.25rem;
    color: var(--sl-color-gray-3, #666);
    font-style: italic;
  }
  .journey-rs-panel .rs-error { color: #cc3206; font-style: normal; }
  /* Transient highlight on the paragraph we scrolled to. */
  .journey-rs-panel .rs-body :target {
    background: #fff6c2;
    transition: background 1.5s ease-out;
  }

  /* Width tiers — map stays usable, article gets real line length. */
  @media (min-width: 1024px) {
    body.journey-preview-open .right-sidebar-container,
    body.journey-preview-open .right-sidebar {
      width: 22rem;
      max-width: 22rem;
    }
  }
  @media (min-width: 1280px) {
    body.journey-preview-open .right-sidebar-container,
    body.journey-preview-open .right-sidebar {
      width: 28rem;
      max-width: 28rem;
    }
  }
  @media (min-width: 1600px) {
    body.journey-preview-open .right-sidebar-container,
    body.journey-preview-open .right-sidebar {
      width: 34rem;
      max-width: 34rem;
    }
  }
</style>

<script>
  const DESKTOP_MIN = 1024;
  const CACHE = new Map<string, string>(); // url (no hash) → fragment HTML
  let originalChildren: Element[] | null = null;
  let panel: HTMLElement | null = null;
  let manifest: Record<string, { title?: string; fragment: string }> | null = null;

  function getHost(): HTMLElement | null {
    return document.querySelector<HTMLElement>('.right-sidebar-panel .sl-container');
  }

  async function getManifest() {
    if (manifest) return manifest;
    try {
      const res = await fetch('/journey-fragments.json');
      if (res.ok) manifest = await res.json();
    } catch {}
    return manifest;
  }

  async function fetchFragment(pathname: string): Promise<string> {
    if (CACHE.has(pathname)) return CACHE.get(pathname)!;
    const m = await getManifest();
    const fragmentUrl = m?.[pathname]?.fragment ?? pathname + 'fragment';
    const res = await fetch(fragmentUrl);
    if (!res.ok) throw new Error(`fragment fetch failed: ${res.status}`);
    const text = await res.text();
    CACHE.set(pathname, text);
    return text;
  }

  function titleFor(pathname: string): string {
    return manifest?.[pathname]?.title ?? 'Article preview';
  }

  function ensurePanel(): HTMLElement | null {
    if (panel) return panel;
    const host = getHost();
    if (!host) return null;
    originalChildren = Array.from(host.children) as Element[];
    for (const el of originalChildren) (el as HTMLElement).style.display = 'none';
    panel = document.createElement('div');
    panel.className = 'journey-rs-panel sl-markdown-content';
    panel.innerHTML = `
      <header>
        <span class="rs-title">Article preview</span>
        <a class="rs-pop" target="_blank" rel="noopener" href="#">Open full →</a>
        <button class="rs-close" type="button" aria-label="Close preview">&times;</button>
      </header>
      <div class="rs-body"><p class="rs-loading">Loading…</p></div>
    `;
    host.append(panel);
    document.body.classList.add('journey-preview-open');
    return panel;
  }

  async function openPreview(pathname: string, hash: string) {
    const p = ensurePanel();
    if (!p) return;
    const body = p.querySelector<HTMLElement>('.rs-body');
    const titleEl = p.querySelector<HTMLElement>('.rs-title');
    const pop = p.querySelector<HTMLAnchorElement>('.rs-pop');
    if (!body || !titleEl || !pop) return;

    pop.href = pathname + (hash ? '#' + hash : '');
    body.innerHTML = `<p class="rs-loading">Loading…</p>`;
    try {
      await getManifest();
      titleEl.textContent = titleFor(pathname);
      const html = await fetchFragment(pathname);
      body.innerHTML = html;
      // Rewrite in-article hash links to scroll within the panel,
      // and open article-to-article links in a new tab (user chose
      // this article as their reading focus; opening another inside
      // the panel would be disorienting).
      body.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
        const href = a.getAttribute('href') || '';
        if (href.startsWith('#')) return; // hash links handled below
        if (href.startsWith('/') && !href.startsWith(pathname)) {
          a.target = '_blank';
          a.rel = 'noopener';
        }
      });
      body.scrollTop = 0;
      if (hash) {
        const target = body.querySelector<HTMLElement>(`#${CSS.escape(hash)}`);
        if (target) {
          body.scrollTop = target.offsetTop - body.offsetTop - 8;
          // Fire :target highlight by briefly moving the URL hash, then
          // taking it back — without causing the parent page to scroll.
          target.setAttribute('id', hash);
          target.scrollIntoView({ block: 'nearest' });
        }
      }
    } catch (err) {
      body.innerHTML = `<p class="rs-error">Couldn't load the article preview. <a href="${pathname}">Open it full-page instead →</a></p>`;
    }
  }

  function closePreview() {
    if (panel) {
      panel.remove();
      panel = null;
    }
    if (originalChildren) {
      for (const el of originalChildren) (el as HTMLElement).style.display = '';
      originalChildren = null;
    }
    document.body.classList.remove('journey-preview-open');
  }

  // Main click delegation.
  document.addEventListener('click', (ev) => {
    const target = ev.target as Element | null;
    if (!target) return;

    // Close button inside the panel.
    if (target.closest('.rs-close')) {
      closePreview();
      return;
    }

    // Hash-only links INSIDE the panel: scroll the panel body, not
    // the parent page.
    const panelAnchor = target.closest<HTMLAnchorElement>('.journey-rs-panel .rs-body a[href^="#"]');
    if (panelAnchor) {
      ev.preventDefault();
      const hash = panelAnchor.getAttribute('href')!.slice(1);
      const body = panelAnchor.closest<HTMLElement>('.rs-body');
      const dest = body?.querySelector<HTMLElement>(`#${CSS.escape(hash)}`);
      if (body && dest) body.scrollTop = dest.offsetTop - body.offsetTop - 8;
      return;
    }

    // Read: nodes on the map.
    if (window.innerWidth < DESKTOP_MIN) return;
    if (ev.metaKey || ev.ctrlKey || ev.shiftKey || ev.button !== 0) return;
    const anchor = target.closest<HTMLAnchorElement>('.journey-svg a');
    if (!anchor) return;
    const href = anchor.getAttribute('href');
    if (!href) return;
    const [pathname, hash = ''] = href.split('#');
    ev.preventDefault();
    openPreview(pathname, hash);
  });

  // Esc closes the panel.
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape' && panel) closePreview();
  });

  // Prefetch the manifest + hovered article's fragment for snappy first click.
  document.addEventListener(
    'pointerover',
    (ev) => {
      if (window.innerWidth < DESKTOP_MIN) return;
      const target = ev.target as Element | null;
      const anchor = target?.closest<HTMLAnchorElement>('.journey-svg a');
      if (!anchor) return;
      const href = anchor.getAttribute('href');
      if (!href) return;
      const [pathname] = href.split('#');
      if (!CACHE.has(pathname)) fetchFragment(pathname).catch(() => {});
    },
    { passive: true },
  );
</script>
