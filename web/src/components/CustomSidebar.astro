---
/**
 * Curated left sidebar for content pages. Light cream panel matching the
 * chat app's sidebar (see the `.sidebar` styles in home.css) — a primary
 * "Ask a question" button on top, curated section lists, and the same
 * "Saving babies with data" footer. No category-tree accordion.
 */
import { getCollection, type CollectionEntry } from 'astro:content';

const JOURNEY = 'Reader Journey';
const JOURNEY_SLUG_ORDER = [
  'pages/journey/index',
  'pages/journey/path-secular-pro-choice',
  'pages/journey/path-christian-pro-choice',
  'pages/journey/path-personally-opposed',
  'pages/journey/path-pro-life-with-exceptions',
  'pages/journey/path-pro-life-incrementalist',
  'pages/journey/path-apathetic-christian',
  'pages/journey/path-anti-abortion-non-christian',
  'pages/journey/next-steps',
];

type Entry = CollectionEntry<'docs'>;
const entries = await getCollection('docs');
const journeyEntries = entries
  .filter((e) => (e.data.categories as string[] | undefined)?.includes(JOURNEY))
  .sort((a: Entry, b: Entry) => {
    const ai = JOURNEY_SLUG_ORDER.indexOf(a.id);
    const bi = JOURNEY_SLUG_ORDER.indexOf(b.id);
    const ax = ai === -1 ? Number.MAX_SAFE_INTEGER : ai;
    const bx = bi === -1 ? Number.MAX_SAFE_INTEGER : bi;
    if (ax !== bx) return ax - bx;
    return a.id.localeCompare(b.id);
  });

const currentPath = Astro.url.pathname.replace(/\/$/, '');
const isCurrent = (id: string) => currentPath === `/${id}`;
---

<nav class="abolition-sidebar" aria-label="Site sections">
  <a href="/" class="ask-cta">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    Ask a question
  </a>

  <div class="section">
    <div class="section-label">Journey</div>
    <ul class="pages">
      {journeyEntries.map((e) => (
        <li>
          <a href={`/${e.id}/`} aria-current={isCurrent(e.id) ? 'page' : undefined}>
            {e.data.title}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="section">
    <div class="section-label">Articles</div>
    <ul class="pages">
      <li>
        <a href="/pages/" aria-current={currentPath === '/pages' ? 'page' : undefined}>
          All articles
        </a>
      </li>
    </ul>
  </div>

  <div class="sidebar-foot">
    <p class="sidebar-tagline">
      Saving babies with data by{' '}
      <a href="https://askscottpierce.com" rel="noopener">Scott Pierce</a>
    </p>
    <div class="sidebar-foot-links">
      <a href="/pages/legal/privacy/">Privacy</a>
      <span aria-hidden="true">·</span>
      <a href="/pages/legal/terms/">Terms</a>
    </div>
  </div>
</nav>

<style is:global>
  /* Let our cream panel paint the whole sidebar column. */
  .sidebar-pane { padding: 0 !important; background: var(--ar-secondary-cream); }
  .sidebar-pane .sidebar-content { padding: 0 !important; }

  .abolition-sidebar {
    background: var(--ar-secondary-cream);
    color: var(--ar-primary);
    font-family: var(--ar-font-body);
    min-height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 0.85rem;
    box-sizing: border-box;
  }

  /* Primary "Ask a question" button — mirrors the chat's New chat button. */
  .abolition-sidebar .ask-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.8rem;
    background: var(--ar-primary);
    color: var(--ar-blush);
    border: 2px solid var(--ar-primary);
    border-radius: var(--ar-radius-btn);
    font-size: 1rem;
    text-decoration: none;
    transition: background var(--ar-duration-fast);
  }
  .abolition-sidebar .ask-cta:hover { background: var(--ar-primary-dark); border-color: var(--ar-primary-dark); }
  .abolition-sidebar .ask-cta svg { flex: none; }

  .abolition-sidebar .section { margin: 0; }
  .abolition-sidebar .section-label {
    font-family: var(--ar-font-caps);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ar-secondary);
    padding: 0.25rem 0.5rem 0.4rem;
  }
  .abolition-sidebar ul.pages { list-style: none; padding: 0; margin: 0; }
  .abolition-sidebar .pages li { margin: 0; }
  .abolition-sidebar .pages a {
    display: block;
    padding: 0.42rem 0.6rem;
    color: var(--ar-primary);
    text-decoration: none;
    line-height: 1.35;
    font-size: 0.92rem;
    border-radius: var(--ar-radius-btn);
    transition: background var(--ar-duration-fast), color var(--ar-duration-fast);
  }
  .abolition-sidebar .pages a:hover { background: var(--ar-blush); }
  .abolition-sidebar .pages a[aria-current='page'] {
    background: var(--ar-blush);
    box-shadow: inset 2px 0 0 var(--ar-tertiary);
    color: var(--ar-primary);
  }

  /* Footer tagline — same as the chat sidebar. */
  .abolition-sidebar .sidebar-foot {
    margin-top: auto;
    border-top: 1px solid var(--ar-secondary);
    padding-top: 1rem;
    font-size: 0.82rem;
    color: var(--ar-secondary);
    line-height: 1.6;
  }
  .abolition-sidebar .sidebar-tagline { margin: 0; }
  .abolition-sidebar .sidebar-tagline a { color: var(--ar-tertiary); text-decoration: none; }
  .abolition-sidebar .sidebar-tagline a:hover { text-decoration: underline; }
  .abolition-sidebar .sidebar-foot-links { margin-top: 0.7rem; display: flex; gap: 0.5rem; }
  .abolition-sidebar .sidebar-foot-links a { color: var(--ar-secondary); text-decoration: none; }
  .abolition-sidebar .sidebar-foot-links a:hover { color: var(--ar-primary); }
</style>
