---
import { ChatBox } from '@/components/ChatBox';
import '@/styles/home.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="only light" />
    <meta name="theme-color" content="#430607" />
    <title>Ask the Abolitionist</title>
    <meta
      name="description"
      content="Beta. Straight answers on abortion from the abolitionist movement. An independent project — not a product of abolitionistsrising.com or freethestates.org, whose writings it draws from."
    />
    <meta property="og:title" content="Ask the Abolitionist (Beta)" />
    <meta
      property="og:description"
      content="Beta. Straight answers on abortion from the abolitionist movement. An independent project — not a product of abolitionistsrising.com or freethestates.org."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://abolitionist.ljs.app/" />
    <meta name="twitter:card" content="summary" />
    {/* twitter:title / :description default to the site; the Worker rewrites
        all OG/twitter tags when serving a shared /c/<id> link so it unfurls
        with the asked question. */}
    <meta name="twitter:title" content="Ask the Abolitionist (Beta)" />
    <meta
      name="twitter:description"
      content="Straight answers on abortion from the abolitionist movement — grounded in its writings and talks, with every source shown."
    />
    <link rel="icon" href="/icon-full.png" type="image/png" />
    <link rel="apple-touch-icon" href="/icon-full.png" />
    <script
      defer
      data-domain="abolitionist.ljs.app"
      data-api="https://plausible.ljs.app/api/event"
      src="https://plausible.ljs.app/js/script.js"></script>
  </head>
  <body class="app">
    {/* Server-rendered heading for SEO — the visible brand lives in the
        (client-rendered) sidebar, claude.ai-style. */}
    <h1 class="sr-only">Ask the Abolitionist</h1>

    {/* The full-height chat application: collapsible sidebar (brand, nav,
        chat history) + conversation. */}
    <ChatBox client:load />
  </body>
</html>
