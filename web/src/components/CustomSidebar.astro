---
/**
 * Curated left sidebar — no category tree, no accordion, just the
 * pages readers actually care about. Matches the visual language of
 * cdn.ljs.app/norman-statement (oxblood panel, small-caps eyebrow
 * labels, restrained list).
 */
import { getCollection, type CollectionEntry } from 'astro:content';

const JOURNEY = 'Reader Journey';
const JOURNEY_SLUG_ORDER = [
  'pages/journey/index',
  'pages/journey/path-secular-pro-choice',
  'pages/journey/path-christian-pro-choice',
  'pages/journey/path-personally-opposed',
  'pages/journey/path-pro-life-with-exceptions',
  'pages/journey/path-pro-life-incrementalist',
  'pages/journey/path-apathetic-christian',
  'pages/journey/path-anti-abortion-non-christian',
  'pages/journey/next-steps',
];

type Entry = CollectionEntry<'docs'>;
const entries = await getCollection('docs');
const journeyEntries = entries
  .filter((e) => (e.data.categories as string[] | undefined)?.includes(JOURNEY))
  .sort((a: Entry, b: Entry) => {
    const ai = JOURNEY_SLUG_ORDER.indexOf(a.id);
    const bi = JOURNEY_SLUG_ORDER.indexOf(b.id);
    const ax = ai === -1 ? Number.MAX_SAFE_INTEGER : ai;
    const bx = bi === -1 ? Number.MAX_SAFE_INTEGER : bi;
    if (ax !== bx) return ax - bx;
    return a.id.localeCompare(b.id);
  });

const currentPath = Astro.url.pathname.replace(/\/$/, '');
const isCurrent = (id: string) => currentPath === `/${id}`;
---

<nav class="abolition-sidebar" aria-label="Site sections">
  <div class="section">
    <div class="section-label">Journey</div>
    <ul class="pages">
      {journeyEntries.map((e) => (
        <li>
          <a href={`/${e.id}/`} aria-current={isCurrent(e.id) ? 'page' : undefined}>
            {e.data.title}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="section">
    <div class="section-label">Articles</div>
    <ul class="pages">
      <li>
        <a
          href="/pages/"
          aria-current={currentPath === '/pages' ? 'page' : undefined}
        >
          All articles
        </a>
      </li>
      <li>
        <a href="/">Ask a question</a>
      </li>
    </ul>
  </div>
</nav>

<style is:global>
  /* Kill Starlight's default sidebar padding so our oxblood panel can
     paint the full column. */
  .sidebar-pane { padding: 0 !important; background: #2b0404; }
  .sidebar-pane .sidebar-content { padding: 0 !important; }

  .abolition-sidebar {
    --sb-bg: #2b0404;
    --sb-fg: #f3e6d0;
    --sb-fg-muted: rgba(243, 230, 208, 0.55);
    --sb-accent: #ffffff;
    --sb-active-bg: rgba(255, 255, 255, 0.08);
    --sb-hover-bg: rgba(255, 255, 255, 0.04);
    --sb-active-rule: #c49a6e;

    background: var(--sb-bg);
    color: var(--sb-fg);
    font-family: 'EB Garamond', Georgia, serif;
    min-height: 100%;
    padding: 1.5rem 0 2rem;
    box-sizing: border-box;
  }
  .abolition-sidebar .section { margin-bottom: 1.25rem; }
  .abolition-sidebar .section:last-child { margin-bottom: 0; }
  .abolition-sidebar .section-label {
    font-family: 'Oswald', Impact, sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sb-fg-muted);
    padding: 0 1.25rem 0.5rem;
    border-bottom: 1px solid rgba(196, 154, 110, 0.2);
    margin: 0 1rem 0.4rem;
  }
  .abolition-sidebar ul.pages {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .abolition-sidebar .pages li { margin: 0; }
  .abolition-sidebar .pages a {
    display: block;
    padding: 0.4rem 1.25rem 0.4rem 1.1rem;
    color: var(--sb-fg);
    text-decoration: none;
    line-height: 1.3;
    font-size: 0.95rem;
    border-left: 3px solid transparent;
    transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;
  }
  .abolition-sidebar .pages a:hover {
    background: var(--sb-hover-bg);
    color: var(--sb-accent);
  }
  .abolition-sidebar .pages a[aria-current='page'] {
    background: var(--sb-active-bg);
    border-left-color: var(--sb-active-rule);
    color: var(--sb-accent);
  }
</style>
