---
/**
 * Journey map + article preview sheet.
 *
 * The flowchart is rendered as an <img> referencing
 * /journey-map.svg with absolutely-positioned <a> overlays for
 * each linked Read: node. Inline SVG was being color-inverted by
 * browsers running force-dark modes (Vivaldi's "Force Dark Pages",
 * Chrome's auto-dark) — they double-invert <img> elements back to
 * their original colors but leave inline SVG inverted along with
 * the page. The <img> approach keeps the diagram readable in those
 * environments without requiring the user to disable a browser-
 * level accessibility option.
 *
 * On MOBILE (<900px), the sheet slides up from the bottom.
 * On DESKTOP (≥900px), the sheet snaps to the right side.
 *
 * Clicking a Read: overlay opens the sheet; clicking the map
 * anywhere else (or the scrim) dismisses it.
 */
import fs from 'node:fs';
import path from 'node:path';
import url from 'node:url';

const here = path.dirname(url.fileURLToPath(import.meta.url));
const excaliPath = path.resolve(here, '../../public/journey-map.excalidraw');

const PAD = 40; // must match scripts/generate-journey-svg.mjs
const doc = JSON.parse(fs.readFileSync(excaliPath, 'utf8'));
const elements = doc.elements.filter((e: any) => !e.isDeleted);

// Recompute the SVG viewBox the same way the generator does so the
// overlay's percentage coords land on the right pixels.
let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
for (const el of elements) {
  if (el.type === 'arrow') {
    const xs = el.points.map((p: number[]) => el.x + p[0]);
    const ys = el.points.map((p: number[]) => el.y + p[1]);
    minX = Math.min(minX, ...xs);
    minY = Math.min(minY, ...ys);
    maxX = Math.max(maxX, ...xs);
    maxY = Math.max(maxY, ...ys);
  } else {
    minX = Math.min(minX, el.x);
    minY = Math.min(minY, el.y);
    maxX = Math.max(maxX, el.x + el.width);
    maxY = Math.max(maxY, el.y + el.height);
  }
}
minX -= PAD; minY -= PAD; maxX += PAD; maxY += PAD;
const vbW = maxX - minX;
const vbH = maxY - minY;

interface LinkOverlay {
  href: string;
  left: number;
  top: number;
  w: number;
  h: number;
  label: string;
}
const byId = new Map<string, any>(elements.map((e: any) => [e.id, e]));
const links: LinkOverlay[] = elements
  .filter((e: any) => e.link && (e.type === 'rectangle' || e.type === 'diamond'))
  .map((el: any) => {
    const boundText = (el.boundElements || []).find((b: any) => b.type === 'text');
    const labelText = boundText ? (byId.get(boundText.id)?.text || '') : '';
    return {
      href: el.link as string,
      left: ((el.x - minX) / vbW) * 100,
      top: ((el.y - minY) / vbH) * 100,
      w: (el.width / vbW) * 100,
      h: (el.height / vbH) * 100,
      label: labelText.replace(/\n/g, ' ').trim(),
    };
  });
---

<figure class="journey-figure">
  <div class="journey-map" style={`aspect-ratio: ${vbW} / ${vbH};`}>
    <img
      class="journey-map-img"
      src="/journey-map.svg"
      alt="Reader Journey flowchart"
      loading="lazy"
      decoding="async"
    />
    <div class="journey-map-overlay" aria-hidden="false">
      {links.map((l) => (
        <a
          class="journey-link"
          href={l.href}
          aria-label={l.label}
          style={`left:${l.left.toFixed(3)}%;top:${l.top.toFixed(3)}%;width:${l.w.toFixed(3)}%;height:${l.h.toFixed(3)}%;`}
        ></a>
      ))}
    </div>
  </div>
  <figcaption>
    Click any &ldquo;Read:&rdquo; box to open that article beside the
    map &mdash; from the right on desktop, from the bottom on phones.
  </figcaption>
</figure>

<div class="js-sheet-scrim" aria-hidden="true"></div>
<aside class="js-sheet" aria-hidden="true" hidden>
  <div class="js-sheet__handle" aria-hidden="true"></div>
  <header class="js-sheet__head">
    <span class="js-sheet__eyebrow">Article</span>
    <h2 class="js-sheet__title">Article preview</h2>
    <a class="js-sheet__pop" target="_blank" rel="noopener" href="#">Open full →</a>
    <button class="js-sheet__close" type="button" aria-label="Close preview">&times;</button>
  </header>
  <div class="js-sheet__body sl-markdown-content">
    <p class="js-sheet__loading">Loading…</p>
  </div>
</aside>

<style is:global>
  .journey-figure { margin: 1.5rem 0; }
  .journey-figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--sl-color-gray-3, #666);
    text-align: center;
  }

  /* No padding here — the overlay percentages assume that the
     overlay box and the image box are identical. Any padding
     creates a content area larger than the image (height grows
     more than width because the SVG is tall+narrow), and the
     percentage-positioned overlays drift further down with each
     successive node. The visual breathing room comes from the
     <figure>'s margin. */
  .journey-map {
    position: relative;
    background: var(--ar-paper, #fff);
    border: 1px solid var(--ar-secondary, #c49a6e);
    border-radius: 4px;
    overflow: hidden; /* keep border-radius from clipping awkwardly */
    color-scheme: only light;
  }
  .journey-map-img {
    display: block;
    width: 100%;
    height: auto;
  }
  .journey-map-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .journey-link {
    position: absolute;
    display: block;
    pointer-events: auto;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s ease, outline 0.15s ease;
  }
  .journey-link:hover { background: rgba(204, 50, 6, 0.07); }
  .journey-link:focus-visible {
    outline: 3px solid var(--ar-tertiary, #cc3206);
    outline-offset: 2px;
  }

  /* ---- Sheet: mobile-first (bottom-up) ---- */
  .js-sheet-scrim {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    pointer-events: none;
    z-index: 100;
    transition: background 0.3s var(--ar-ease, ease-in-out);
  }
  .js-sheet-scrim.open {
    background: rgba(35, 1, 2, 0.38);
    pointer-events: auto;
    cursor: pointer;
  }
  .js-sheet {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    max-height: 82vh;
    background: var(--ar-paper, #fff);
    border-top: 3px solid var(--ar-secondary, #c49a6e);
    border-top-left-radius: 18px;
    border-top-right-radius: 18px;
    transform: translateY(100%);
    transition: transform 0.35s var(--ar-ease, ease-in-out);
    z-index: 101;
    box-shadow: 0 -20px 50px rgba(0, 0, 0, 0.35);
    padding-bottom: env(safe-area-inset-bottom, 0);
    display: flex;
    flex-direction: column;
  }
  .js-sheet[hidden] { display: none; }
  .js-sheet.open { transform: translateY(0); }
  .js-sheet__handle {
    width: 48px;
    height: 4px;
    background: var(--ar-secondary, #c49a6e);
    border-radius: 2px;
    margin: 0.65rem auto 0;
    flex: 0 0 auto;
  }
  .js-sheet__head {
    position: relative;
    padding: 0.6rem 3.25rem 0.7rem 1.25rem;
    border-bottom: 1px solid rgba(196, 154, 110, 0.4);
    flex: 0 0 auto;
  }
  .js-sheet__eyebrow {
    display: block;
    font-family: var(--ar-font-caps, 'Oswald', Impact, sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ar-secondary, #c49a6e);
    margin: 0 0 0.1rem;
  }
  .js-sheet__title {
    font-family: var(--ar-font-display, 'Cinzel Decorative', serif);
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1.2;
    color: var(--ar-primary, #430607);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .js-sheet__pop {
    display: inline-block;
    margin-top: 0.3rem;
    font-family: var(--ar-font-body, 'EB Garamond', serif);
    font-size: 0.75rem;
    color: var(--ar-tertiary, #cc3206);
    text-decoration: underline;
  }
  .js-sheet__pop:hover { color: var(--ar-tertiary-hover, #e93807); }
  .js-sheet__close {
    position: absolute;
    top: 0.55rem;
    right: 0.6rem;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: var(--ar-paper, #fff);
    border: 1.5px solid var(--ar-secondary, #c49a6e);
    border-radius: 999px;
    color: var(--ar-primary, #430607);
    font-size: 1.2rem;
    line-height: 1;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .js-sheet__close:hover {
    background: var(--ar-primary, #430607);
    color: var(--ar-secondary-cream, #f8f2ed);
  }
  .js-sheet__close:active { transform: scale(0.92); }
  .js-sheet__body {
    padding: 1rem 1.25rem 1.25rem;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    flex: 1 1 auto;
    font-size: 17px;
    line-height: 1.55;
  }
  .js-sheet__body :is(p, li, blockquote) { font-size: 17px; }
  .js-sheet__body :is(h1, h2, h3, h4, h5, h6):first-child { margin-top: 0; }
  .js-sheet__body h1 { font-size: 1.75rem; line-height: 1.15; }
  .js-sheet__body h2 { font-size: 1.35rem; line-height: 1.2; }
  .js-sheet__body h3 { font-size: 1.15rem; }
  .js-sheet__body h4 { font-size: 1.05rem; }
  .js-sheet__loading { color: var(--ar-secondary, #c49a6e); font-style: italic; }
  .js-sheet__error { color: var(--ar-tertiary, #cc3206); }
  .js-sheet__body .rs-flash {
    animation: rs-flash-fade 1.8s ease-out;
    border-radius: 2px;
  }
  @keyframes rs-flash-fade {
    from { background-color: #fff3b0; }
    to   { background-color: transparent; }
  }

  body.journey-preview-open { overflow: hidden; }

  /* ---- Sheet: desktop (right-side rail) ---- */
  @media (min-width: 900px) {
    body.journey-preview-open { overflow: auto; }
    .js-sheet-scrim { display: none !important; }
    .js-sheet {
      top: var(--sl-nav-height, 4rem);
      bottom: 0;
      left: auto;
      right: 0;
      width: 26rem;
      max-height: none;
      height: calc(100vh - var(--sl-nav-height, 4rem));
      transform: translateX(100%);
      transition: transform 0.3s var(--ar-ease, ease-in-out);
      border-top: none;
      border-left: 1px solid var(--ar-secondary, #c49a6e);
      border-top-left-radius: 0;
      border-top-right-radius: 0;
      box-shadow: -4px 0 30px rgba(0, 0, 0, 0.22);
      padding-bottom: 0;
    }
    .js-sheet.open { transform: translateX(0); }
    .js-sheet__handle { display: none; }
  }
  @media (min-width: 1280px) {
    .js-sheet { width: 30rem; }
  }
  @media (min-width: 1600px) {
    .js-sheet { width: 36rem; }
  }
</style>

<script>
  const CACHE = new Map<string, { title: string; body: string }>();

  function $<E extends Element = HTMLElement>(sel: string, root: ParentNode = document): E | null {
    return root.querySelector<E>(sel);
  }

  function fragmentUrlFor(pathname: string): string {
    const p = pathname.endsWith('/') ? pathname : pathname + '/';
    return p + 'fragment/';
  }

  async function fetchFragment(pathname: string) {
    const cached = CACHE.get(pathname);
    if (cached) return cached;
    const res = await fetch(fragmentUrlFor(pathname));
    if (!res.ok) throw new Error(`fragment fetch failed: ${res.status}`);
    const html = await res.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const title = doc.querySelector('h1')?.textContent?.trim() || 'Article preview';
    const body = doc.body.innerHTML;
    const entry = { title, body };
    CACHE.set(pathname, entry);
    return entry;
  }

  async function openSheet(pathname: string, hash: string) {
    const sheet = $<HTMLElement>('.js-sheet');
    const scrim = $<HTMLElement>('.js-sheet-scrim');
    const body = $<HTMLElement>('.js-sheet__body');
    const titleEl = $<HTMLElement>('.js-sheet__title');
    const pop = $<HTMLAnchorElement>('.js-sheet__pop');
    if (!sheet || !scrim || !body || !titleEl || !pop) return;

    sheet.hidden = false;
    sheet.setAttribute('aria-hidden', 'false');
    // eslint-disable-next-line @typescript-eslint/no-unused-expressions
    sheet.offsetWidth;
    sheet.classList.add('open');
    scrim.classList.add('open');
    document.body.classList.add('journey-preview-open');

    pop.href = pathname + (hash ? '#' + hash : '');
    body.innerHTML = `<p class="js-sheet__loading">Loading…</p>`;
    try {
      const { title, body: html } = await fetchFragment(pathname);
      titleEl.textContent = title;
      body.innerHTML = html;
      body.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
        const href = a.getAttribute('href') || '';
        if (href.startsWith('#')) return;
        if (href.startsWith('/') && !href.startsWith(pathname)) {
          a.target = '_blank';
          a.rel = 'noopener';
        }
      });
      body.scrollTop = 0;
      if (hash) {
        const target = body.querySelector<HTMLElement>(`#${CSS.escape(hash)}`);
        if (target) {
          const t = target.getBoundingClientRect().top;
          const p = body.getBoundingClientRect().top;
          body.scrollTop += t - p - 12;
          target.classList.add('rs-flash');
          window.setTimeout(() => target.classList.remove('rs-flash'), 1800);
        }
      }
    } catch {
      body.innerHTML = `<p class="js-sheet__error">Couldn't load the article preview. <a href="${pathname}">Open it full-page →</a></p>`;
    }
  }

  function closeSheet() {
    const sheet = $<HTMLElement>('.js-sheet');
    const scrim = $<HTMLElement>('.js-sheet-scrim');
    if (!sheet || !scrim) return;
    sheet.classList.remove('open');
    scrim.classList.remove('open');
    sheet.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('journey-preview-open');
    window.setTimeout(() => { sheet.hidden = true; }, 400);
  }

  document.addEventListener('click', (ev) => {
    const t = ev.target as Element | null;
    if (!t) return;

    if (t.closest('.js-sheet__close') || t.classList.contains('js-sheet-scrim')) {
      closeSheet();
      return;
    }

    const innerHashAnchor = t.closest<HTMLAnchorElement>(
      '.js-sheet__body a[href^="#"]',
    );
    if (innerHashAnchor) {
      ev.preventDefault();
      const hash = innerHashAnchor.getAttribute('href')!.slice(1);
      const body = innerHashAnchor.closest<HTMLElement>('.js-sheet__body');
      const dest = body?.querySelector<HTMLElement>(`#${CSS.escape(hash)}`);
      if (body && dest) {
        const a = dest.getBoundingClientRect().top;
        const b = body.getBoundingClientRect().top;
        body.scrollTop += a - b - 12;
      }
      return;
    }

    if (ev.metaKey || ev.ctrlKey || ev.shiftKey || ev.button !== 0) return;
    const anchor = t.closest<HTMLAnchorElement>('.journey-map a.journey-link');
    if (anchor) {
      const href = anchor.getAttribute('href');
      if (!href) return;
      const [pathname, hash = ''] = href.split('#');
      ev.preventDefault();
      openSheet(pathname, hash);
      return;
    }

    // Click on the map (or anywhere outside the sheet) while open → dismiss.
    const sheet = $<HTMLElement>('.js-sheet');
    if (sheet?.classList.contains('open') && !t.closest('.js-sheet')) {
      closeSheet();
    }
  });

  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') closeSheet();
  });

  // Prefetch fragment on hover for snappy first open.
  document.addEventListener(
    'pointerover',
    (ev) => {
      const t = ev.target as Element | null;
      const anchor = t?.closest<HTMLAnchorElement>('.journey-map a.journey-link');
      if (!anchor) return;
      const href = anchor.getAttribute('href');
      if (!href) return;
      const [pathname] = href.split('#');
      if (!CACHE.has(pathname)) fetchFragment(pathname).catch(() => {});
    },
    { passive: true },
  );
</script>
