---
/**
 * Inlines web/public/journey-map.svg into the journey page in
 * normal document flow — no inner scroll container, so the map
 * scrolls with the rest of the page. On desktop (lg+ breakpoint)
 * clicks on Read: nodes hijack Starlight's right "On this page"
 * sidebar and load the article into an iframe there, preserving
 * the reader's place in the map. Narrow viewports fall through to
 * normal full-page navigation.
 */
import fs from 'node:fs';
import path from 'node:path';
import url from 'node:url';

const here = path.dirname(url.fileURLToPath(import.meta.url));
const svgPath = path.resolve(here, '../../public/journey-map.svg');
const raw = fs
  .readFileSync(svgPath, 'utf8')
  .replace(/^<\?xml[^?]*\?>\s*/, '')
  .replace('<svg ', '<svg class="journey-svg" ');
---

<figure class="journey-figure">
  <div class="journey-map" set:html={raw} />
  <figcaption>
    Click any &ldquo;Read:&rdquo; box to open the article. On desktop
    it loads in the right sidebar so you keep your place in the map;
    on phones it opens the article full-page.
  </figcaption>
</figure>

<style is:global>
  .journey-figure { margin: 1.5rem 0; }
  .journey-figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--sl-color-gray-3, #666);
    text-align: center;
  }
  .journey-map .journey-svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .journey-svg a { cursor: pointer; }
  .journey-svg a:hover rect { filter: brightness(0.95); }
  .journey-svg a:focus-visible rect { outline: 3px solid #cc3206; }

  /* Right-sidebar iframe panel (injected on click). */
  .journey-rs-panel {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--sl-nav-height, 4rem) - 1rem);
    border: 1px solid var(--sl-color-hairline, #c49a6e);
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }
  .journey-rs-panel > header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    background: #430607;
    color: #fde8e8;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 0.85rem;
  }
  .journey-rs-panel .rs-title { flex: 1; }
  .journey-rs-panel .rs-pop {
    color: #fde8e8;
    text-decoration: underline;
    font-size: 0.75rem;
  }
  .journey-rs-panel .rs-close {
    background: transparent;
    border: 0;
    color: #fde8e8;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .journey-rs-panel iframe {
    flex: 1;
    width: 100%;
    border: 0;
    background: #fff;
  }
  /* Widen the right column while the preview is open so an article
     body is actually legible. Only on xl and above to avoid crunching
     the map column. */
  @media (min-width: 80rem) {
    body.journey-preview-open {
      --sl-sidebar-width: 22rem;
    }
    body.journey-preview-open .right-sidebar-container,
    body.journey-preview-open .right-sidebar {
      width: 26rem;
      max-width: 26rem;
    }
  }
</style>

<script>
  // Desktop-only: clicking a Read: anchor inside .journey-svg swaps
  // Starlight's right-sidebar ToC for an iframe loaded with the
  // article. Close restores the ToC.
  const DESKTOP_MIN = 1024;
  let originalChildren: Element[] | null = null;
  let panel: HTMLElement | null = null;

  function getHost(): HTMLElement | null {
    return document.querySelector<HTMLElement>('.right-sidebar-panel .sl-container');
  }

  function openPreview(href: string) {
    const host = getHost();
    if (!host) return;

    if (!originalChildren) {
      originalChildren = Array.from(host.children) as Element[];
      for (const el of originalChildren) (el as HTMLElement).style.display = 'none';
    }

    if (!panel) {
      panel = document.createElement('div');
      panel.className = 'journey-rs-panel';
      panel.innerHTML = `
        <header>
          <span class="rs-title">Article preview</span>
          <a class="rs-pop" target="_blank" rel="noopener" href="#">Open full</a>
          <button class="rs-close" type="button" aria-label="Close preview">&times;</button>
        </header>
        <iframe title="Article preview" src="about:blank"></iframe>
      `;
      host.append(panel);
    }

    const iframe = panel.querySelector<HTMLIFrameElement>('iframe');
    const pop = panel.querySelector<HTMLAnchorElement>('.rs-pop');
    if (iframe) iframe.src = href;
    if (pop) pop.href = href;
    document.body.classList.add('journey-preview-open');
  }

  function closePreview() {
    if (panel) {
      panel.remove();
      panel = null;
    }
    if (originalChildren) {
      for (const el of originalChildren) (el as HTMLElement).style.display = '';
      originalChildren = null;
    }
    document.body.classList.remove('journey-preview-open');
  }

  document.addEventListener('click', (ev) => {
    const target = ev.target as Element | null;
    if (target?.classList.contains('rs-close')) {
      closePreview();
      return;
    }

    if (window.innerWidth < DESKTOP_MIN) return;
    if (ev.metaKey || ev.ctrlKey || ev.shiftKey || ev.button !== 0) return;
    if (!target) return;
    const anchor = target.closest('.journey-svg a');
    if (!anchor) return;
    const href = anchor.getAttribute('href');
    if (!href) return;

    ev.preventDefault();
    openPreview(href);
  });
</script>
